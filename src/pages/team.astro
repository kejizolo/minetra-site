---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Michael Chen',
    role: 'Chief Executive Officer',
    image: '/images/team/member-1.jpg',
    bio: 'With over 20 years of experience in mining operations and management.',
  },
  {
    name: 'Sarah Williams',
    role: 'Operations Director',
    image: '/images/team/member-2.jpg',
    bio: 'Expert in streamlining mining operations for maximum efficiency.',
  },
  {
    name: 'David Rodriguez',
    role: 'Chief Engineer',
    image: '/images/team/member-3.jpg',
    bio: 'Leading our engineering team with innovative solutions.',
  },
  {
    name: 'Emily Johnson',
    role: 'Safety Manager',
    image: '/images/team/member-4.jpg',
    bio: 'Ensuring the highest safety standards across all projects.',
  },
  {
    name: 'James Wilson',
    role: 'Project Manager',
    image: '/images/team/member-5.jpg',
    bio: 'Delivering projects on time and within budget.',
  },
  {
    name: 'Lisa Anderson',
    role: 'Environmental Specialist',
    image: '/images/team/member-2.jpg',
    bio: 'Championing sustainable mining practices.',
  },
  {
    name: 'Robert Taylor',
    role: 'Mining Engineer',
    image: '/images/team/member-6.jpg',
    bio: 'Technical expert in extraction methodologies.',
  },
  {
    name: 'Jennifer Martinez',
    role: 'Geologist',
    image: '/images/team/member-4.jpg',
    bio: 'Specializing in resource assessment and exploration.',
  },
];

const faqs = [
  {
    question: 'What qualifications do your team members have?',
    answer: 'Our team consists of certified professionals with degrees in engineering, geology, and related fields, plus extensive industry experience.',
  },
  {
    question: 'How do you ensure continuous professional development?',
    answer: 'We invest in ongoing training and certification programs to keep our team at the forefront of industry best practices.',
  },
  {
    question: 'Do you work with international teams?',
    answer: 'Yes, we collaborate with experts worldwide and have multilingual capabilities to serve global projects.',
  },
  {
    question: 'What is your approach to safety training?',
    answer: 'Safety is paramount. All team members undergo rigorous safety training and regular refresher courses.',
  },
  {
    question: 'How experienced is your leadership team?',
    answer: 'Our leadership team has over 100 combined years of experience in the mining industry.',
  },
];
---

<Layout title="Our Team | Minetra Mining & Industrial Solutions">
  <!-- Hero Section -->
  <section class="relative min-h-[450px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero/team-hero.jpg" 
        alt="Mining operations"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/60 to-black/80"></div>
    </div>
    <div class="container-custom relative z-10 text-center text-white py-24">
      <nav class="mb-6">
        <ol class="flex items-center justify-center gap-3 text-sm">
          <li><a href="/" class="text-gray-300 hover:text-[#F5A623] transition">Home</a></li>
          <li class="text-gray-500">/</li>
          <li><span class="text-[#F5A623]">Team</span></li>
        </ol>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">TEAM</h1>
      <div class="w-20 h-1 bg-[#F5A623] mx-auto"></div>
    </div>
  </section>

  <!-- Team Grid Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container-custom">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">Our Team</span>
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[44px] font-bold text-[#1A1A1A] mb-4">
          Meet Our Expert Team
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto">
          Our team of experienced professionals brings together decades of expertise in mining operations, engineering, and project management.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {team.map((member, index) => (
          <div class="group bg-white overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-[#F5A623]">
            <div class="relative overflow-hidden">
              <img 
                src={member.image}
                alt={member.name}
                class="w-full aspect-[3/4] object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-[#F5A623]/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="flex items-center gap-3">
                  <a href="#" class="w-10 h-10 bg-white flex items-center justify-center hover:bg-[#1A1A1A] hover:text-white transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                  </a>
                  <a href="#" class="w-10 h-10 bg-white flex items-center justify-center hover:bg-[#1A1A1A] hover:text-white transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                  </a>
                  <a href="#" class="w-10 h-10 bg-white flex items-center justify-center hover:bg-[#1A1A1A] hover:text-white transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                  </a>
                </div>
              </div>
            </div>
            <div class="p-6 text-center">
              <h3 class="text-lg font-bold text-[#1A1A1A] group-hover:text-[#F5A623] transition-colors">{member.name}</h3>
              <p class="text-[#F5A623] text-sm mt-1 mb-3">{member.role}</p>
              <p class="text-gray-500 text-xs leading-relaxed">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero/contact-hero.jpg" 
        alt="Mining site"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-[#1A1A1A]/85"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] font-semibold uppercase tracking-[3px] text-sm">Get Started</span>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[52px] font-bold text-white mb-6 leading-tight">
          Start Your Next Mining Project With Confidence
        </h2>
        <p class="text-gray-300 mb-10 text-lg max-w-xl">
          Partner with industry experts who understand the complexities of modern mining operations.
        </p>
        <a href="/contact" class="bg-[#F5A623] text-white px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#e09520] transition-all duration-300 inline-flex items-center gap-2 group">
          Get In Touch
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Join Team CTA -->
  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="container-custom">
      <div class="bg-[#F5A623] p-8 lg:p-16 text-center text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/10 rounded-full translate-y-1/2 -translate-x-1/2"></div>
        <div class="relative z-10">
          <h2 class="text-2xl lg:text-4xl font-bold mb-4">
            Want to Join Our Team?
          </h2>
          <p class="mb-8 max-w-2xl mx-auto text-white/90">
            We're always looking for talented individuals who are passionate about mining and industrial innovation. Check out our current openings.
          </p>
          <a href="/contact" class="inline-flex items-center gap-2 bg-white text-[#1A1A1A] px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#1A1A1A] hover:text-white transition-all duration-300 group">
            View Careers
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container-custom">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">FAQ</span>
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[44px] font-bold text-[#1A1A1A]">
          Frequently Asked Questions
        </h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq, index) => (
          <details class="group bg-gray-50 border border-gray-200 open:border-[#F5A623] open:bg-white transition-all duration-300">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none select-none">
              <span class="font-semibold text-[#1A1A1A] pr-8 text-base group-hover:text-[#F5A623] transition-colors">{faq.question}</span>
              <div class="w-8 h-8 bg-white group-hover:bg-[#F5A623] flex items-center justify-center flex-shrink-0 transition-colors duration-300 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500 group-hover:text-white transition-all duration-300 group-open:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </summary>
            <div class="px-6 pb-6 text-gray-500 leading-relaxed border-t border-gray-200 pt-4">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
