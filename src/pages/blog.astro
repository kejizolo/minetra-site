---
import Layout from '../layouts/Layout.astro';

const blogPosts = [
  {
    title: 'Role of Engineering in Developing Advanced Mining Systems',
    excerpt: 'Exploring how modern engineering is revolutionizing the mining industry with cutting-edge technologies and innovative approaches.',
    image: '/images/blog/post-1.jpg',
    category: 'ENGINEERING',
    date: 'March 16, 2026',
    slug: 'post-1',
  },
  {
    title: 'Engineering Innovation Transforming Modern Mining Operations',
    excerpt: 'New technologies are changing the way we approach mining operations, from automation to AI-driven resource management.',
    image: '/images/blog/post-2.jpg',
    category: 'INNOVATION',
    date: 'March 15, 2026',
    slug: 'post-2',
  },
  {
    title: 'Mining Industry Supporting Modern Industrial Infrastructure',
    excerpt: 'The critical role of mining in building modern infrastructure and supporting global economic development.',
    image: '/images/blog/post-3.jpg',
    category: 'INDUSTRY',
    date: 'March 14, 2026',
    slug: 'post-3',
  },
  {
    title: 'Industrial Growth Driven by Reliable Mining Resource Supply',
    excerpt: 'How consistent and reliable mining operations contribute to sustained industrial growth and development.',
    image: '/images/blog/post-4.jpg',
    category: 'INDUSTRY',
    date: 'March 13, 2026',
    slug: 'post-4',
  },
  {
    title: 'Sustainable Mining Practices Improving Resource Extraction',
    excerpt: 'Environmental responsibility in mining operations and the adoption of sustainable extraction methods.',
    image: '/images/blog/post-5.jpg',
    category: 'SUSTAINABILITY',
    date: 'March 12, 2026',
    slug: 'post-5',
  },
  {
    title: 'Modern Mining Operations Supporting Resource Development',
    excerpt: 'An in-depth look at how modern mining techniques are optimizing resource development and extraction.',
    image: '/images/blog/post-6.jpg',
    category: 'OPERATIONS',
    date: 'March 11, 2026',
    slug: 'post-6',
  },
];

const categories = [
  { name: 'All', count: 12 },
  { name: 'Engineering', count: 4 },
  { name: 'Innovation', count: 3 },
  { name: 'Industry', count: 3 },
  { name: 'Sustainability', count: 2 },
];
---

<Layout title="Blog | Minetra Mining & Industrial Solutions">
  <!-- Hero Section -->
  <section class="relative min-h-[450px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero/blog-hero.jpg" 
        alt="Mining operations"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/60 to-black/80"></div>
    </div>
    <div class="container-custom relative z-10 text-center text-white py-24">
      <nav class="mb-6">
        <ol class="flex items-center justify-center gap-3 text-sm">
          <li><a href="/" class="text-gray-300 hover:text-[#F5A623] transition">Home</a></li>
          <li class="text-gray-500">/</li>
          <li><span class="text-[#F5A623]">Blog</span></li>
        </ol>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">BLOG</h1>
      <div class="w-20 h-1 bg-[#F5A623] mx-auto"></div>
    </div>
  </section>

  <!-- Blog Grid Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container-custom">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">Blog</span>
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[44px] font-bold text-[#1A1A1A] mb-4">
          From Our Blog
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto">
          Stay updated with the latest insights, industry trends, and expert perspectives on mining and industrial development.
        </p>
      </div>

      <!-- Categories Filter -->
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {categories.map((cat, index) => (
          <button class={`px-6 py-2 text-sm font-semibold uppercase tracking-wider transition-all duration-300 ${index === 0 ? 'bg-[#F5A623] text-white' : 'bg-gray-100 text-gray-600 hover:bg-[#F5A623] hover:text-white'}`}>
            {cat.name} ({cat.count})
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {blogPosts.map((post, index) => (
          <article class="bg-white border border-gray-100 overflow-hidden group hover:shadow-xl transition-all duration-300">
            <div class="relative overflow-hidden aspect-[16/10]">
              <img 
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <span class="absolute top-4 left-4 bg-[#F5A623] text-white text-xs font-semibold px-4 py-2 uppercase tracking-wider">
                {post.category}
              </span>
            </div>
            <div class="p-6 lg:p-8">
              <div class="flex items-center gap-2 text-gray-400 text-sm mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                <span>{post.date}</span>
              </div>
              <h3 class="text-lg font-bold text-[#1A1A1A] mb-3 line-clamp-2 group-hover:text-[#F5A623] transition-colors">
                {post.title}
              </h3>
              <p class="text-gray-500 text-sm mb-4 line-clamp-2 leading-relaxed">{post.excerpt}</p>
              <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-2 text-[#F5A623] font-semibold text-sm hover:gap-3 transition-all group/link">
                Read More
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/link:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Pagination -->
      <div class="flex justify-center items-center gap-2 mt-16">
        <button class="w-12 h-12 border border-gray-200 flex items-center justify-center hover:bg-[#F5A623] hover:border-[#F5A623] hover:text-white transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button class="w-12 h-12 bg-[#F5A623] text-white flex items-center justify-center font-semibold">1</button>
        <button class="w-12 h-12 border border-gray-200 flex items-center justify-center hover:bg-[#F5A623] hover:border-[#F5A623] hover:text-white transition-all duration-300 font-semibold">2</button>
        <button class="w-12 h-12 border border-gray-200 flex items-center justify-center hover:bg-[#F5A623] hover:border-[#F5A623] hover:text-white transition-all duration-300 font-semibold">3</button>
        <button class="w-12 h-12 border border-gray-200 flex items-center justify-center hover:bg-[#F5A623] hover:border-[#F5A623] hover:text-white transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="container-custom">
      <div class="bg-[#1A1A1A] p-8 lg:p-16 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-[#F5A623]/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#F5A623]/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
        <div class="relative z-10 text-center max-w-2xl mx-auto">
          <div class="flex items-center justify-center gap-3 mb-4">
            <div class="w-8 h-[2px] bg-[#F5A623]"></div>
            <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">Newsletter</span>
            <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          </div>
          <h2 class="text-2xl lg:text-4xl font-bold text-white mb-4">
            Subscribe to Our Newsletter
          </h2>
          <p class="mb-8 text-gray-400">
            Get the latest updates on mining projects, industry insights, and company news delivered to your inbox.
          </p>
          <form class="flex flex-col sm:flex-row gap-4" onsubmit="event.preventDefault();">
            <input 
              type="email" 
              placeholder="Your email address" 
              class="flex-1 px-6 py-4 bg-white/10 border border-white/20 text-white placeholder-gray-500 focus:outline-none focus:border-[#F5A623] transition-colors"
            />
            <button type="submit" class="bg-[#F5A623] text-white px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#e09520] transition-all duration-300 whitespace-nowrap">
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
