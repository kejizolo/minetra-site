    title: 'Role of Engineering in Developing Advanced Mining Systems',
    excerpt: 'Exploring how modern engineering is revolutionizing the mining industry.',
    image: '/images/blog/post-1.jpg',
    category: 'ENGINEERING',
    date: 'March 16, 2026',
  },
  {
    title: 'Engineering Innovation Transforming Modern Mining Operations',
    excerpt: 'New technologies are changing the way we approach mining operations.',
    image: '/images/blog/post-2.jpg',
    category: 'INNOVATION',
    date: 'March 15, 2026',
  },
  {
    title: 'Mining Industry Supporting Modern Industrial Infrastructure',
    excerpt: 'The critical role of mining in building modern infrastructure.',
    image: '/images/blog/post-3.jpg',
    category: 'INDUSTRY',
    date: 'March 14, 2026',
  },
];

const features = [
  { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Quality Assurance', description: 'Rigorous quality control standards' },
  { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Fast Execution', description: 'Efficient project delivery' },
  { icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', title: 'Secure Operations', description: 'Advanced safety protocols' },
  { icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064', title: 'Global Reach', description: 'International project experience' },
  { icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', title: 'Certified Experts', description: 'Industry-certified professionals' },
  { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: '24/7 Support', description: 'Round-the-clock assistance' },
];
---

<Layout title="Minetra - Mining & Industrial Solutions | Home">
  <!-- Hero Section -->
  <section class="relative min-h-[700px] lg:min-h-[800px] flex items-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img 
        src="/images/hero/portainer-hero.jpg" 
        alt="Container port with shipping containers"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1A1A1A]/75 via-[#1A1A1A]/50 to-transparent"></div>
    </div>
    
    <div class="container-custom relative z-10 py-20 lg:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
        <!-- Left Content - 8 columns -->
        <div class="lg:col-span-7 text-white">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-[2px] bg-[#F5A623]"></div>
            <p class="text-[#F5A623] text-sm font-semibold uppercase tracking-[4px]">Welcome to Minetra</p>
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-[64px] font-bold mb-6 leading-[1.1]">
            <span class="text-white drop-shadow-[0_2px_10px_rgba(0,0,0,0.8)]">ENGINEERING THE</span><br/>
            <span class="text-[#F5A623] drop-shadow-[0_2px_10px_rgba(0,0,0,0.5)]">FUTURE</span> <span class="text-white drop-shadow-[0_2px_10px_rgba(0,0,0,0.8)]">OF MINING</span>
          </h1>
          <p class="text-white/90 text-base lg:text-lg mb-10 max-w-xl leading-relaxed drop-shadow-md">
            Delivering innovative mining services and industrial expertise to support sustainable resource development and long-term industry growth.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/services" class="bg-[#F5A623] text-white px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#e09520] transition-all duration-300 inline-flex items-center gap-2 group shadow-lg">
              Our Services
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="/about" class="border-2 border-white/50 text-white px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-white hover:text-[#1A1A1A] transition-all duration-300 backdrop-blur-sm">
              Learn More
            </a>
          </div>
        </div>
        
        <!-- Right Contact Card - 4 columns -->
        <div class="lg:col-span-5">
          <div class="bg-white/95 backdrop-blur-sm p-8 lg:p-10 shadow-2xl max-w-md ml-auto relative border border-white/20">
            <div class="absolute -top-3 -right-3 w-20 h-20 bg-[#F5A623] flex items-center justify-center shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#1A1A1A] mb-2">Get Free Consultation</h3>
            <p class="text-gray-600 text-sm mb-6">Our experts are ready to help you achieve your goals.</p>
            <div class="border-t border-gray-200 pt-6">
              <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Call Us Today</p>
              <p class="text-3xl font-bold text-[#F5A623] mb-6">+1 415 704 3021</p>
              <a href="/contact" class="block w-full bg-[#1A1A1A] text-white text-center px-6 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#F5A623] transition-all duration-300">
                Get a Quote
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Icons Section with Image -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Image -->
        <div class="relative">
          <div class="relative overflow-hidden rounded-lg">
            <img 
              src="/images/features-bg.jpg" 
              alt="Construction equipment at work"
              class="w-full h-[400px] object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/60 to-transparent"></div>
          </div>
          <div class="absolute -bottom-6 -right-6 bg-[#F5A623] text-white p-6 shadow-xl">
            <span class="text-4xl font-bold block">100%</span>
            <span class="text-sm uppercase tracking-wider">Commitment</span>
          </div>
        </div>
        <!-- Right: Features Grid -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-[2px] bg-[#F5A623]"></div>
            <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">Why Choose Us</span>
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#1A1A1A] mb-8">
            Features That Set Us Apart
          </h2>
          <div class="grid grid-cols-2 gap-6">
            {features.map(feature => (
              <div class="flex items-start gap-4 group">
                <div class="w-12 h-12 bg-[#F5A623]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[#F5A623] transition-colors duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#F5A623] group-hover:text-white transition-colors duration-300">
                    <path d={feature.icon} />
                  </svg>
                </div>
                <div>
                  <h4 class="text-sm font-semibold text-[#1A1A1A] group-hover:text-[#F5A623] transition-colors">{feature.title}</h4>
                  <p class="text-xs text-gray-500 mt-1">{feature.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section with Side Image -->
  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Left: Services Cards -->
        <div class="lg:col-span-7">
          <div class="mb-12">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-8 h-[2px] bg-[#F5A623]"></div>
              <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">What We Offer</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-[#1A1A1A] leading-tight">
              Comprehensive Mining & Industrial Services
            </h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map((service, index) => (
              <div class="bg-white p-6 group hover:shadow-xl transition-all duration-300 relative overflow-hidden border-l-4 border-transparent hover:border-[#F5A623]">
                <div class="w-14 h-14 bg-[#F5A623]/10 flex items-center justify-center mb-4 group-hover:bg-[#F5A623] transition-colors duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#F5A623] group-hover:text-white transition-colors duration-300">
                    <path d={service.icon} />
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-[#1A1A1A] mb-2 group-hover:text-[#F5A623] transition-colors">{service.title}</h3>
                <p class="text-gray-500 text-sm leading-relaxed">{service.description}</p>
              </div>
            ))}
          </div>
        </div>
        <!-- Right: Image -->
        <div class="lg:col-span-5 relative">
          <div class="relative overflow-hidden rounded-lg">
            <img 
              src="/images/services-bg.jpg" 
              alt="Industrial mining equipment"
              class="w-full h-[500px] lg:h-[600px] object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/70 via-transparent to-transparent"></div>
          </div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="bg-white/95 backdrop-blur-sm p-6 shadow-xl">
              <p class="text-[#F5A623] text-sm font-semibold uppercase tracking-wider mb-2">Our Expertise</p>
              <p class="text-[#1A1A1A] font-bold text-lg">Delivering Excellence in Every Project</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section with Background Image -->
  <section class="relative py-20 lg:py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/stats-bg.jpg" 
        alt="Industrial warehouse with containers"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0F0F0F]/95 via-[#1A1A1A]/90 to-[#2A2A2A]/85"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {stats.map((stat, index) => (
          <div class="text-center text-white p-6 group">
            <div class="w-20 h-20 mx-auto bg-[#F5A623]/20 border border-[#F5A623]/30 flex items-center justify-center mb-6 group-hover:bg-[#F5A623] transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#F5A623] group-hover:text-white transition-colors duration-300">
                <path d={stat.icon} />
              </svg>
            </div>
            <span class="text-5xl lg:text-6xl font-bold text-white block mb-2">{stat.number}</span>
            <p class="text-gray-400 text-sm uppercase tracking-wider">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-12 lg:py-16 bg-gray-50">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="relative">
          <div class="relative overflow-hidden">
            <img 
              src="/images/about-excavator.jpg" 
              alt="Yellow excavator at mining site"
              class="w-full h-[450px] lg:h-[550px] object-cover"
            />
          </div>
          <!-- Experience Badge -->
          <div class="absolute -bottom-6 -right-6 lg:bottom-8 lg:-right-8 bg-[#F5A623] text-white p-8 text-center shadow-2xl">
            <span class="text-5xl lg:text-6xl font-bold block">25+</span>
            <span class="text-sm uppercase tracking-wider">Years Experience</span>
          </div>
          <!-- Decorative Element -->
          <div class="absolute -top-4 -left-4 w-24 h-24 border-2 border-[#F5A623] -z-10"></div>
        </div>
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-[2px] bg-[#F5A623]"></div>
            <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">About Us</span>
          </div>
          <h2 class="text-2xl md:text-3xl lg:text-[40px] font-bold text-[#1A1A1A] mb-6 leading-tight">
            Delivering Reliable Mining Solutions With Focus on Safety, Efficiency & Sustainable Development
          </h2>
          <p class="text-gray-500 mb-8 leading-relaxed">
            With over two decades of experience in the mining industry, Minetra has established itself as a leader in providing innovative and sustainable mining solutions. Our team of expert engineers and technicians work tirelessly to ensure every project meets the highest standards.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            {[
              'Advanced Technology Integration',
              'Environmental Responsibility',
              'Certified Safety Standards',
              '24/7 Support & Maintenance'
            ].map(item => (
              <div class="flex items-center gap-3">
                <div class="w-6 h-6 bg-[#F5A623] flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M20 6 9 17l-5-5"/></svg>
                </div>
                <span class="text-[#1A1A1A] font-medium text-sm">{item}</span>
              </div>
            ))}
          </div>
          <a href="/about" class="bg-[#F5A623] text-white px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#e09520] transition-all duration-300 inline-flex items-center gap-2 group">
            Read More
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container-custom">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">Our Portfolio</span>
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[44px] font-bold text-[#1A1A1A] leading-tight max-w-3xl mx-auto">
          Explore Our Latest Mining Projects
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {projects.map(project => (
          <div class="group relative overflow-hidden bg-white shadow-lg hover:shadow-2xl transition-all duration-500">
            <div class="relative overflow-hidden aspect-[4/3]">
              <img 
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-full group-hover:translate-y-0 transition-transform duration-500">
                <a href="/project" class="inline-flex items-center gap-2 text-white font-semibold text-sm">
                  View Project
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </div>
            <div class="p-6">
              <span class="text-[#F5A623] text-xs font-semibold uppercase tracking-wider">{project.category}</span>
              <h3 class="text-xl font-bold text-[#1A1A1A] mt-2 group-hover:text-[#F5A623] transition-colors">{project.title}</h3>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/project" class="inline-flex items-center gap-2 border-2 border-[#1A1A1A] text-[#1A1A1A] px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#1A1A1A] hover:text-white transition-all duration-300 group">
          View All Projects
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero/contact-hero.jpg" 
        alt="Mining site"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-[#1A1A1A]/85"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] font-semibold uppercase tracking-[3px] text-sm">Get Started</span>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[52px] font-bold text-white mb-6 leading-tight">
          Start Your Next Mining Project With Confidence
        </h2>
        <p class="text-gray-300 mb-10 text-lg max-w-xl">
          Partner with industry experts who understand the complexities of modern mining operations.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="bg-[#F5A623] text-white px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#e09520] transition-all duration-300 inline-flex items-center gap-2 group">
            Get In Touch
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/services" class="border-2 border-white/30 text-white px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-white hover:text-[#1A1A1A] transition-all duration-300">
            Our Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container-custom">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">Testimonials</span>
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[44px] font-bold text-[#1A1A1A]">
          What Our Clients Say
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {testimonials.map(testimonial => (
          <div class="bg-gray-50 p-8 lg:p-10 relative">
            <div class="absolute top-0 left-0 w-1 h-full bg-[#F5A623]"></div>
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="text-[#F5A623]/20 absolute top-6 right-6"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
            <p class="text-gray-600 mb-8 leading-relaxed relative z-10 text-base">{testimonial.content}</p>
            <div class="flex items-center gap-4">
              <img src={testimonial.avatar} alt={testimonial.author} class="w-14 h-14 rounded-full object-cover border-2 border-[#F5A623]" />
              <div>
                <h4 class="font-bold text-[#1A1A1A] text-lg">{testimonial.author}</h4>
                <p class="text-[#F5A623] text-sm">{testimonial.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="container-custom">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">FAQ</span>
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[44px] font-bold text-[#1A1A1A]">
          Frequently Asked Questions
        </h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.slice(0, 4).map((faq, index) => (
          <details class="group bg-white border border-gray-200 open:border-[#F5A623] transition-colors duration-300">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none select-none">
              <span class="font-semibold text-[#1A1A1A] pr-8 text-base group-hover:text-[#F5A623] transition-colors">{faq.question}</span>
              <div class="w-8 h-8 bg-gray-100 group-hover:bg-[#F5A623] flex items-center justify-center flex-shrink-0 transition-colors duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500 group-hover:text-white transition-all duration-300 group-open:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </summary>
            <div class="px-6 pb-6 text-gray-500 leading-relaxed border-t border-gray-100 pt-4">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Preview Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container-custom">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">Latest News</span>
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[44px] font-bold text-[#1A1A1A]">
          From Our Blog
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {blogPosts.map(post => (
          <article class="bg-white border border-gray-100 overflow-hidden group hover:shadow-xl transition-all duration-300">
            <div class="relative overflow-hidden aspect-[16/10]">
              <img 
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <span class="absolute top-4 left-4 bg-[#F5A623] text-white text-xs font-semibold px-4 py-2 uppercase tracking-wider">
                {post.category}
              </span>
            </div>
            <div class="p-6 lg:p-8">
              <div class="flex items-center gap-2 text-gray-400 text-sm mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                <span>{post.date}</span>
              </div>
              <h3 class="text-lg font-bold text-[#1A1A1A] mb-3 line-clamp-2 group-hover:text-[#F5A623] transition-colors">
                {post.title}
              </h3>
              <p class="text-gray-500 text-sm mb-4 line-clamp-2 leading-relaxed">{post.excerpt}</p>
              <a href="/blog" class="inline-flex items-center gap-2 text-[#F5A623] font-semibold text-sm hover:gap-3 transition-all group/link">
                Read More
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/link:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
