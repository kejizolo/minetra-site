    title: 'Resource Development',
    description: 'Sustainable development strategies to maximize resource utilization while minimizing environmental impact.',
  },
  {
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
    title: 'Safety Consulting',
    description: 'Expert safety assessments and training programs to ensure compliance with industry regulations.',
  },
