---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'post-1' } },
    { params: { slug: 'post-2' } },
    { params: { slug: 'post-3' } },
    { params: { slug: 'post-4' } },
    { params: { slug: 'post-5' } },
    { params: { slug: 'post-6' } },
  ];
}

const { slug } = Astro.params;

const post = {
  title: 'Modern Mining Operations Supporting Resource Development',
  date: 'March 16, 2026',
  author: 'Minetra Team',
  category: 'INDUSTRY',
  featuredImage: '/images/blog/post-1.jpg',
  content: `
    <p>The mining industry has undergone a remarkable transformation over the past decade, driven by technological innovation and a growing emphasis on sustainable practices. At Minetra, we've been at the forefront of this evolution, implementing cutting-edge solutions that enhance efficiency while minimizing environmental impact.</p>
    
    <p>Modern mining operations are no longer just about extraction; they're about creating value through responsible resource development. This approach requires a delicate balance between meeting global resource demands and preserving the environment for future generations.</p>
  `,
  sections: [
    {
      title: 'The Role of Technology in Mining',
      content: 'Technology has revolutionized every aspect of mining operations. From autonomous vehicles to AI-powered resource mapping, modern tools have dramatically improved both safety and efficiency.',
      image: '/images/blog/post-2.jpg',
    },
    {
      title: 'Safety Standards in Mining Operations',
      content: 'Safety remains our top priority. We implement rigorous training programs, regular equipment inspections, and comprehensive emergency response protocols to protect our workers and the surrounding communities.',
    },
    {
      title: 'Environmental Responsibility in Mining Projects',
      content: 'Environmental stewardship is integrated into every project we undertake. From water management to land rehabilitation, we ensure that our operations leave a positive legacy.',
      image: '/images/blog/post-5.jpg',
    },
  ],
  tags: ['Mining', 'Technology', 'Sustainability', 'Innovation'],
};

const relatedPosts = [
  {
    title: 'Engineering Innovation Transforming Modern Mining',
    image: '/images/blog/post-3.jpg',
    date: 'March 15, 2026',
  },
  {
    title: 'Sustainable Mining Practices for the Future',
    image: '/images/blog/post-4.jpg',
    date: 'March 14, 2026',
  },
  {
    title: 'Industrial Growth Through Mining Excellence',
    image: '/images/blog/post-6.jpg',
    date: 'March 13, 2026',
  },
];
---

<Layout title={`${post.title} | Minetra Blog`}>
  <!-- Hero Section -->
  <section class="relative min-h-[400px] flex items-center justify-center">
    <div class="absolute inset-0">
      <img 
        src={post.featuredImage}
        alt={post.title}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-dark/60"></div>
    </div>
    <div class="container-custom relative z-10 text-center text-white py-20">
      <nav class="mb-6">
        <ol class="flex items-center justify-center gap-2 text-sm text-gray-300">
          <li><a href="/" class="hover:text-primary transition">HOME</a></li>
          <li>/</li>
          <li><a href="/blog" class="hover:text-primary transition">BLOG</a></li>
          <li>/</li>
          <li><span class="text-primary">{post.category}</span></li>
        </ol>
      </nav>
      <h1 class="text-hero-mobile lg:text-hero mb-4">{post.title}</h1>
      <div class="flex items-center justify-center gap-4 text-sm text-gray-300">
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          {post.date}
        </span>
        <span>|</span>
        <span>{post.author}</span>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <article class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <!-- Main Image -->
        <img 
          src={post.featuredImage}
          alt={post.title}
          class="w-full aspect-[21/9] object-cover mb-12"
        />
        
        <!-- Intro Content -->
        <div class="prose prose-lg max-w-none text-gray-600 mb-12" set:html={post.content} />
        
        <!-- Sections -->
        {post.sections.map((section, index) => (
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-dark mb-4">{section.title}</h2>
            {section.image && index % 2 === 0 && (
              <img 
                src={section.image}
                alt={section.title}
                class="w-full aspect-[16/9] object-cover mb-6"
              />
            )}
            <p class="text-gray-600 leading-relaxed">{section.content}</p>
            {section.image && index % 2 !== 0 && (
              <img 
                src={section.image}
                alt={section.title}
                class="w-full aspect-[16/9] object-cover mt-6"
              />
            )}
          </div>
        ))}
        
        <!-- Tags -->
        <div class="border-t border-gray-200 pt-8 mt-12">
          <div class="flex flex-wrap items-center gap-4">
            <span class="font-semibold text-dark">TAGS:</span>
            {post.tags.map(tag => (
              <a href="#" class="px-4 py-2 bg-gray-100 text-gray-600 text-sm hover:bg-primary hover:text-white transition">
                {tag}
              </a>
            ))}
          </div>
        </div>
        
        <!-- Share -->
        <div class="flex items-center gap-4 mt-8">
          <span class="font-semibold text-dark">SHARE:</span>
          <div class="flex items-center gap-3">
            <a href="#" class="w-10 h-10 bg-gray-100 flex items-center justify-center hover:bg-primary hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="#" class="w-10 h-10 bg-gray-100 flex items-center justify-center hover:bg-primary hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
            </a>
            <a href="#" class="w-10 h-10 bg-gray-100 flex items-center justify-center hover:bg-primary hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- Related Posts -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <h2 class="text-2xl font-bold text-dark mb-8">RELATED POSTS</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {relatedPosts.map(related => (
          <article class="card overflow-hidden group">
            <div class="relative overflow-hidden">
              <img 
                src={related.image}
                alt={related.title}
                class="w-full aspect-[16/10] object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 text-gray-400 text-sm mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                <span>{related.date}</span>
              </div>
              <h3 class="text-lg font-bold text-dark group-hover:text-primary transition">
                {related.title}
              </h3>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
