---
import Layout from '../layouts/Layout.astro';

const contactInfo = [
  {
    icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z',
    title: 'Phone',
    content: '+1 415 704 3021',
    subContent: 'Mon-Fri: 8am - 6pm',
  },
  {
    icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6',
    title: 'Email',
    content: 'contact@minetra.com',
    subContent: '24/7 online support',
  },
  {
    icon: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 7a3 3 0 1 0 0 6 3 3 0 0 0 0-6z',
    title: 'Address',
    content: '123 Mining Street',
    subContent: 'San Francisco, CA 94105',
  },
];

const faqs = [
  {
    question: 'What services does Minetra offer?',
    answer: 'We offer comprehensive mining services including exploration, extraction, processing, and environmental management. Our team of experts can handle projects of any scale.',
  },
  {
    question: 'How can I request a quote?',
    answer: 'You can request a quote by filling out our contact form, calling our office directly, or sending us an email. Our team will respond within 24 hours.',
  },
  {
    question: 'Do you work internationally?',
    answer: 'Yes, we have experience working on mining projects across multiple continents. Our team is equipped to handle international operations and regulatory requirements.',
  },
  {
    question: 'What is your approach to safety?',
    answer: 'Safety is our top priority. We maintain rigorous safety standards, provide comprehensive training, and continuously monitor and improve our safety protocols.',
  },
  {
    question: 'How do you ensure environmental responsibility?',
    answer: 'We implement sustainable mining practices, conduct thorough environmental impact assessments, and develop comprehensive rehabilitation plans for all our projects.',
  },
];
---

<Layout title="Contact Us | Minetra Mining & Industrial Solutions">
  <!-- Hero Section -->
  <section class="relative min-h-[450px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero/contact-hero-new.jpg" 
        alt="Mining operations"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#1A1A1A]/80 via-[#1A1A1A]/70 to-[#1A1A1A]/85"></div>
    </div>
    <div class="container-custom relative z-10 text-center text-white py-24">
      <nav class="mb-6">
        <ol class="flex items-center justify-center gap-3 text-sm">
          <li><a href="/" class="text-gray-300 hover:text-[#F5A623] transition">Home</a></li>
          <li class="text-gray-500">/</li>
          <li><span class="text-[#F5A623]">Contact</span></li>
        </ol>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">CONTACT</h1>
      <div class="w-20 h-1 bg-[#F5A623] mx-auto"></div>
    </div>
  </section>

  <!-- Contact Info Cards -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 -mt-32 relative z-20">
        {contactInfo.map(info => (
          <div class="bg-[#1A1A1A] p-8 lg:p-10 text-center text-white group hover:bg-[#F5A623] transition-all duration-300">
            <div class="w-16 h-16 mx-auto bg-[#F5A623] flex items-center justify-center mb-6 group-hover:bg-white transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white group-hover:text-[#1A1A1A] transition-colors duration-300">
                <path d={info.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">{info.title}</h3>
            <p class="text-[#F5A623] group-hover:text-white font-semibold transition-colors">{info.content}</p>
            <p class="text-gray-400 text-sm group-hover:text-white/80 transition-colors">{info.subContent}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Form -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-[2px] bg-[#F5A623]"></div>
            <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">Get In Touch</span>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1A1A1A] mb-6">
            Send Us a Message
          </h2>
          <p class="text-gray-500 mb-10 leading-relaxed">
            Have a question or want to discuss your next mining project? Fill out the form below and our team will get back to you within 24 hours.
          </p>
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold text-[#1A1A1A] mb-2">Your Name *</label>
                <input 
                  type="text" 
                  name="name"
                  required
                  class="w-full px-4 py-4 bg-white border border-gray-200 focus:border-[#F5A623] focus:outline-none transition-colors"
                  placeholder="John Doe"
                />
              </div>
              <div>
                <label class="block text-sm font-semibold text-[#1A1A1A] mb-2">Your Email *</label>
                <input 
                  type="email" 
                  name="email"
                  required
                  class="w-full px-4 py-4 bg-white border border-gray-200 focus:border-[#F5A623] focus:outline-none transition-colors"
                  placeholder="john@example.com"
                />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold text-[#1A1A1A] mb-2">Phone Number</label>
                <input 
                  type="tel"
                  name="phone"
                  class="w-full px-4 py-4 bg-white border border-gray-200 focus:border-[#F5A623] focus:outline-none transition-colors"
                  placeholder="+1 234 567 890"
                />
              </div>
              <div>
                <label class="block text-sm font-semibold text-[#1A1A1A] mb-2">Subject *</label>
                <select 
                  name="subject"
                  required
                  class="w-full px-4 py-4 bg-white border border-gray-200 focus:border-[#F5A623] focus:outline-none transition-colors"
                >
                  <option value="">Select a subject</option>
                  <option value="general">General Inquiry</option>
                  <option value="quote">Request Quote</option>
                  <option value="partnership">Partnership</option>
                  <option value="careers">Careers</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-sm font-semibold text-[#1A1A1A] mb-2">Your Message *</label>
              <textarea 
                name="message"
                required
                rows="6"
                class="w-full px-4 py-4 bg-white border border-gray-200 focus:border-[#F5A623] focus:outline-none transition-colors resize-none"
                placeholder="Tell us about your project or inquiry..."
              ></textarea>
            </div>
            <div id="form-status" class="hidden"></div>
            <button 
              type="submit"
              id="submit-btn"
              class="bg-[#F5A623] text-white px-10 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#e09520] transition-all duration-300 inline-flex items-center gap-2 group disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="btn-text">Send Message</span>
              <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
              <svg id="btn-spinner" class="hidden animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
            </button>
          </form>
        </div>

        <!-- Map & Additional Info -->
        <div class="space-y-8">
          <div class="bg-[#1A1A1A] p-8 lg:p-10 text-white">
            <h3 class="text-2xl font-bold mb-6">Office Hours</h3>
            <div class="space-y-4">
              <div class="flex justify-between items-center pb-4 border-b border-white/10">
                <span class="text-gray-400">Monday - Friday</span>
                <span class="font-semibold">8:00 AM - 6:00 PM</span>
              </div>
              <div class="flex justify-between items-center pb-4 border-b border-white/10">
                <span class="text-gray-400">Saturday</span>
                <span class="font-semibold">9:00 AM - 2:00 PM</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-gray-400">Sunday</span>
                <span class="font-semibold text-[#F5A623]">Closed</span>
              </div>
            </div>
          </div>

          <div class="relative aspect-[4/3] bg-gray-200 overflow-hidden">
            <img 
              src="/images/hero/about-hero.jpg"
              alt="Minetra Office Location"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
              <a 
                href="https://www.google.com/maps/search/?api=1&query=浙江省绍兴市诸暨市店口镇" 
                target="_blank"
                class="bg-[#F5A623] text-white px-6 py-3 font-semibold uppercase tracking-wider text-sm hover:bg-[#e09520] transition-all duration-300 inline-flex items-center gap-2"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                View on Map
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container-custom">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
          <span class="text-[#F5A623] text-sm font-semibold uppercase tracking-[3px]">FAQ</span>
          <div class="w-8 h-[2px] bg-[#F5A623]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[44px] font-bold text-[#1A1A1A]">
          Frequently Asked Questions
        </h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq, index) => (
          <details class="group bg-gray-50 border border-gray-200 open:border-[#F5A623] open:bg-white transition-all duration-300">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none select-none">
              <span class="font-semibold text-[#1A1A1A] pr-8 text-base group-hover:text-[#F5A623] transition-colors">{faq.question}</span>
              <div class="w-8 h-8 bg-white group-hover:bg-[#F5A623] flex items-center justify-center flex-shrink-0 transition-colors duration-300 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500 group-hover:text-white transition-all duration-300 group-open:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </summary>
            <div class="px-6 pb-6 text-gray-500 leading-relaxed border-t border-gray-200 pt-4">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero/services-hero.jpg" 
        alt="Mining operations"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-[#1A1A1A]/85"></div>
    </div>
    <div class="container-custom relative z-10 text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="w-8 h-[2px] bg-[#F5A623]"></div>
        <span class="text-[#F5A623] font-semibold uppercase tracking-[3px] text-sm">Ready to Start?</span>
        <div class="w-8 h-[2px] bg-[#F5A623]"></div>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-[52px] font-bold text-white mb-6 leading-tight">
        Let's Build Your Next<br/>Mining Project Together
      </h2>
      <p class="text-gray-300 mb-10 text-lg max-w-2xl mx-auto">
        Partner with industry experts who understand the complexities of modern mining operations and are committed to delivering exceptional results.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="tel:+14157043021" class="bg-[#F5A623] text-white px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-[#e09520] transition-all duration-300 inline-flex items-center gap-2 group">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call Us Now
        </a>
        <a href="mailto:contact@minetra.com" class="border-2 border-white/30 text-white px-8 py-4 font-semibold uppercase tracking-wider text-sm hover:bg-white hover:text-[#1A1A1A] transition-all duration-300 inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email Us
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
const form = document.getElementById('contact-form') as HTMLFormElement;
const statusDiv = document.getElementById('form-status');
const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
const btnText = document.getElementById('btn-text');
const btnIcon = document.getElementById('btn-icon');
const btnSpinner = document.getElementById('btn-spinner');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  
  const formData = new FormData(form);
  const data = {
    name: formData.get('name'),
    email: formData.get('email'),
    phone: formData.get('phone'),
    subject: formData.get('subject'),
    message: formData.get('message'),
  };
  
  setLoading(true);
  
  try {
    // 使用 Cloudflare Pages Functions 路径
    const response = await fetch('/contact', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(data),
    });
    
    const result = await response.json();
    
    if (result.success) {
      showStatus(result.message, 'success');
      form.reset();
    } else {
      showStatus(result.message, 'error');
    }
  } catch (error) {
    showStatus('An error occurred. Please try again later.', 'error');
  } finally {
    setLoading(false);
  }
});

function setLoading(loading: boolean) {
  if (loading) {
    submitBtn.disabled = true;
    btnText!.textContent = 'Sending...';
    btnIcon!.classList.add('hidden');
    btnSpinner!.classList.remove('hidden');
  } else {
    submitBtn.disabled = false;
    btnText!.textContent = 'Send Message';
    btnIcon!.classList.remove('hidden');
    btnSpinner!.classList.add('hidden');
  }
}

function showStatus(message: string, type: 'success' | 'error') {
  if (!statusDiv) return;
  
  statusDiv.classList.remove('hidden');
  statusDiv.className = `p-4 rounded ${type === 'success' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200'}`;
  statusDiv.innerHTML = `
    <div class="flex items-center gap-2">
      ${type === 'success' 
        ? '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg>'
        : '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>'
      }
      <span>${message}</span>
    </div>
  `;
  
  setTimeout(() => {
    statusDiv.classList.add('hidden');
  }, 5000);
}
</script>
